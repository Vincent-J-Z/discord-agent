# Pipeline / task credentials for Mochi_Bot's container.
#
# Copy to the WORKSPACE as `secrets.env` (NOT committed) and fill in only what
# you want to grant. The bridge loads this into the environment that the agent's
# `claude` and its shell commands inherit, so any task it runs (pipeline, S3,
# PRs) can use them. Changes hot-reload — no container restart needed.
#
#   cp secrets.env.example ~/discordAgentWorkspace/secrets.env
#   chmod 600 ~/discordAgentWorkspace/secrets.env
#
# ⚠️ Anyone who can @ the bot can make it use these. Grant the minimum:
# prefer a DEV/read-only DSN and a fine-scoped GitHub token over prod-wide keys.

# ── Database (the "prod DSN" the bot was missing) ─────────────────────────────
# SUPABASE_DB_URL=postgresql://user:pass@host:5432/postgres

# ── AWS S3 (IR media storage) ─────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET_NAME=dk-audio-video
# S3_REGION=us-east-1

# ── GitHub (open/merge PRs via gh) ────────────────────────────────────────────
# GH_TOKEN=ghp_...

# ── LLM / data API keys the pipeline calls ────────────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# FMP_API_KEY=
