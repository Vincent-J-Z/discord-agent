import os, sys
sys.path.insert(0, "mcp-server/scripts")
from catalog import open_catalog_readonly

conn = open_catalog_readonly()
cur = conn.cursor()

for ticker in ("MIRM", "NTRA"):
    cur.execute("SELECT count(*) FROM ir_media_catalog WHERE ticker = %s", (ticker,))
    total = cur.fetchone()[0]
    cur.execute(
        "SELECT extract(year from event_date)::int as yr, count(*) "
        "FROM ir_media_catalog WHERE ticker = %s GROUP BY yr ORDER BY yr",
        (ticker,),
    )
    by_year = cur.fetchall()
    cur.execute(
        "SELECT count(*) FROM ir_media_catalog WHERE ticker = %s AND event_date = %s",
        (ticker, "2026-05-19"),
    )
    has_0519 = cur.fetchone()[0]
    print(f"=== {ticker} ===")
    print(f"  total catalog rows: {total}")
    print(f"  by year: {by_year}")
    if ticker == "MIRM":
        print(f"  2026-05-19 rows: {has_0519}")
