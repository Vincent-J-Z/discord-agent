# Optional compose-only settings.
# Copy to .env beside compose.yaml if your host needs overrides.

# Host directory mounted into the container at /workspace.
# Default in compose.yaml is: ${HOME}/discordAgentWorkspace
# DISCORD_AGENT_WORKSPACE_HOST=/absolute/path/to/discordAgentWorkspace

# Host directory holding the source code, mounted into the container at /app
# (writable, so the agent's edits land here on the host).
# Default in compose.yaml is the compose project directory: .
# DISCORD_AGENT_SOURCE_HOST=/absolute/path/to/discord_agent

# Optional Linux UID/GID for bind-mount writes.
# On macOS/Docker Desktop this can usually stay unset.
# On Linux, set these to match the host user:
#   HOST_UID=$(id -u)
#   HOST_GID=$(id -g)
# HOST_UID=1000
# HOST_GID=1000
