DISCORD_BOT_TOKEN=replace_me
# Fallback / status-board channel. Still used when DISCORD_GUILD_ID is blank.
DISCORD_CHANNEL_ID=replace_me
# Which servers to watch (poll fallback + hourly sweep + channel listing).
# Blank = EVERY server the bot has joined (true multi-server). Set one guild id,
# or a comma-separated list, to restrict. Note: @-mention replies work in any
# server regardless of this — it only scopes the proactive/enumeration features.
DISCORD_GUILD_ID=
DISCORD_BOT_ID=replace_me
# Optional. Leave blank to trigger only on direct bot mentions.
DISCORD_ROLE_ID=
# What the agent calls itself — in replies, prompts, and the monitor.
AGENT_NAME=Claude Agent
TICK_SECONDS=60

# Host-only Claude Code bridge settings.
# Set this after running `claude setup-token` outside the container.
CLAUDE_CODE_OAUTH_TOKEN=

# Leave BOT_ALLOWED_USER_IDS empty to allow anyone in the channel to call the bot.
# Prefer a comma-separated whitelist for real use, e.g. 123,456.
BOT_ALLOWED_USER_IDS=
CLAUDE_BIN=claude
# Where Claude runs. Point at the mounted source tree (/app in the container) so
# the agent can read and edit its own code when a session asks it to.
CLAUDE_CWD=/app
# Where Claude stores sessions/config. Point at the workspace so per-channel
# conversations (claude --resume) survive container rebuilds.
CLAUDE_CONFIG_DIR=/workspace/.claude
# Per-channel session continuity: 1 = each channel/thread keeps context across
# messages (resume); 0 = stateless one-shot each time.
SESSION_RESUME=1
CLAUDE_MODEL=
# Reasoning effort: low | medium | high | xhigh | max. Higher = more thinking
# (better on hard tasks, slower, more quota). Blank = claude's default.
CLAUDE_EFFORT=
# Permission mode for the in-container claude:
#   bypassPermissions — can run shell, post, edit code, etc. (full autonomy;
#                        rely on the container as the isolation boundary)
#   dontAsk          — read/write files only; ALL shell execution is blocked
#   default/acceptEdits/plan — standard Claude Code modes
CLAUDE_PERMISSION_MODE=bypassPermissions
CLAUDE_TIMEOUT_SECONDS=240
# How many recent channel messages to feed Claude as context (0 = none).
HISTORY_LIMIT=20
# Proactive hourly sweep. If there's NO new activity, the agent isn't even
# started (no cost). If there is, it reviews and stays SILENT unless something
# genuinely needs a reply/action. 0 disables. SWEEP_REPORT_CHANNEL is only used
# for proactive notes not tied to a specific channel (default: DISCORD_CHANNEL_ID).
SWEEP_INTERVAL_SECONDS=3600
SWEEP_REPORT_CHANNEL=
