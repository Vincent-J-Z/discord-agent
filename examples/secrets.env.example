# Optional task / dev credentials for the agent's container.
#
# Copy to the WORKSPACE as `secrets.env` (NOT committed) and fill in only what
# you want to grant. The bridge loads this into the environment that the agent's
# `claude` and its shell commands inherit, so any task it runs can use them.
# Changes hot-reload — no container restart needed.
#
#   cp secrets.env.example ~/discordAgentWorkspace/secrets.env
#   chmod 600 ~/discordAgentWorkspace/secrets.env
#
# ⚠️ Anyone who can @ the bot can make it use these. Grant the minimum:
# prefer DEV/read-only credentials and fine-scoped tokens over prod-wide keys.
# These are EXAMPLES — add or remove whatever your own tasks actually need.

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── AWS / S3 ──────────────────────────────────────────────────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# S3_BUCKET_NAME=

# ── GitHub (open/merge PRs via gh) ────────────────────────────────────────────
# GH_TOKEN=

# ── LLM / data API keys ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
