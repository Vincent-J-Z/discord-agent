DISCORD_BOT_TOKEN=replace_me
# Fallback / status-board channel. Still used when DISCORD_GUILD_ID is blank.
DISCORD_CHANNEL_ID=replace_me
# Set this to watch EVERY readable text channel in the guild, so the bot can be
# @-mentioned from any channel and replies go back to that channel. Leave blank
# to stay single-channel (DISCORD_CHANNEL_ID only).
DISCORD_GUILD_ID=
DISCORD_BOT_ID=replace_me
# Optional. Leave blank to trigger only on direct bot mentions.
DISCORD_ROLE_ID=
TICK_SECONDS=60

# Host-only Claude Code bridge settings.
# Set this after running `claude setup-token` outside the container.
CLAUDE_CODE_OAUTH_TOKEN=

# Leave BOT_ALLOWED_USER_IDS empty to allow anyone in the channel to call the bot.
# Prefer a comma-separated whitelist for real use, e.g. 123,456.
BOT_ALLOWED_USER_IDS=
CLAUDE_BIN=claude
# Where Claude runs. Point at the mounted source tree (/app in the container) so
# the agent can read and edit its own code when a session asks it to.
CLAUDE_CWD=/app
CLAUDE_MODEL=
# Permission mode for the in-container claude:
#   bypassPermissions — can run shell, post, edit code, etc. (full autonomy;
#                        rely on the container as the isolation boundary)
#   dontAsk          — read/write files only; ALL shell execution is blocked
#   default/acceptEdits/plan — standard Claude Code modes
CLAUDE_PERMISSION_MODE=bypassPermissions
CLAUDE_TIMEOUT_SECONDS=240
# How many recent channel messages to feed Claude as context (0 = none).
HISTORY_LIMIT=20
